/* Chain Lens - Modern Bitcoin Transaction Visualizer */

/* ===== CSS Variables ===== */
:root {
    /* Brand Colors */
    --bitcoin-orange: #f7931a;
    --bitcoin-orange-dark: #d97b00;
    --bitcoin-orange-light: #ffb347;

    /* Background */
    --bg-dark: #0d1117;
    --bg-card: #161b22;
    --bg-elevated: #21262d;
    --bg-input: #0d1117;

    /* Text */
    --text-primary: #f0f6fc;
    --text-secondary: #8b949e;
    --text-muted: #6e7681;

    /* Status Colors */
    --success: #3fb950;
    --success-bg: rgba(63, 185, 80, 0.15);
    --warning: #d29922;
    --warning-bg: rgba(210, 153, 34, 0.15);
    --error: #f85149;
    --error-bg: rgba(248, 81, 73, 0.15);
    --info: #58a6ff;
    --info-bg: rgba(88, 166, 255, 0.15);

    /* Gradients */
    --gradient-primary: linear-gradient(135deg, var(--bitcoin-orange) 0%, var(--bitcoin-orange-dark) 100%);
    --gradient-card: linear-gradient(145deg, var(--bg-card) 0%, var(--bg-elevated) 100%);

    /* Spacing */
    --radius-sm: 6px;
    --radius-md: 12px;
    --radius-lg: 16px;
    --radius-xl: 24px;

    /* Shadows */
    --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.4);
    --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.5);
    --shadow-glow: 0 0 20px rgba(247, 147, 26, 0.3);

    /* Transitions */
    --transition-fast: 150ms ease;
    --transition-normal: 250ms ease;
    --transition-slow: 400ms ease;
}

/* ===== Reset & Base ===== */
*,
*::before,
*::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    font-size: 16px;
    scroll-behavior: smooth;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', sans-serif;
    background: var(--bg-dark);
    color: var(--text-primary);
    line-height: 1.6;
    min-height: 100vh;
}

/* ===== App Container ===== */
.app {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

/* ===== Header ===== */
.header {
    text-align: center;
    padding: 2rem 0 3rem;
}

.logo {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
}

.logo-icon {
    font-size: 2.5rem;
    animation: swing 2s ease-in-out infinite;
}

@keyframes swing {

    0%,
    100% {
        transform: rotate(-5deg);
    }

    50% {
        transform: rotate(5deg);
    }
}

.logo h1 {
    font-size: 2.5rem;
    font-weight: 700;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.tagline {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

/* ===== Input Panel ===== */
.input-panel {
    flex: 1;
    display: flex;
    align-items: flex-start;
    justify-content: center;
}

.input-card {
    background: var(--gradient-card);
    border: 1px solid var(--bg-elevated);
    border-radius: var(--radius-xl);
    padding: 2rem;
    width: 100%;
    max-width: 700px;
    box-shadow: var(--shadow-lg);
}

.input-card h2 {
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    font-size: 1.5rem;
}

.helper-text {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
}

/* Input Tabs */
.input-tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
}

.input-tab {
    padding: 0.6rem 1.25rem;
    background: transparent;
    border: 1px solid var(--bg-elevated);
    color: var(--text-secondary);
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    cursor: pointer;
    font-size: 0.9rem;
    transition: all var(--transition-fast);
}

.input-tab:hover {
    color: var(--text-primary);
    border-color: var(--text-muted);
}

.input-tab.active {
    background: var(--bitcoin-orange);
    border-color: var(--bitcoin-orange);
    color: white;
}

.tab-panel {
    display: none;
}

.tab-panel.active {
    display: block;
}

/* Textarea */
textarea {
    width: 100%;
    min-height: 200px;
    padding: 1rem;
    background: var(--bg-input);
    border: 2px solid var(--bg-elevated);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-family: 'Monaco', 'Menlo', 'Fira Code', monospace;
    font-size: 0.9rem;
    resize: vertical;
    transition: border-color var(--transition-fast);
}

textarea:focus {
    outline: none;
    border-color: var(--bitcoin-orange);
}

textarea::placeholder {
    color: var(--text-muted);
}

/* Buttons */
.btn-analyze {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 1rem;
    margin-top: 1rem;
    background: var(--gradient-primary);
    border: none;
    border-radius: var(--radius-md);
    color: white;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
    box-shadow: var(--shadow-md);
}

.btn-analyze:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
}

.btn-analyze:active {
    transform: translateY(0);
}

.btn-icon {
    font-size: 1.2rem;
}

/* Demo Panel */
.demo-text {
    color: var(--text-secondary);
    margin-bottom: 1rem;
}

.demo-options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
}

.demo-btn {
    padding: 0.75rem 1.25rem;
    background: var(--bg-elevated);
    border: 1px solid var(--text-muted);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: 0.9rem;
    cursor: pointer;
    transition: all var(--transition-fast);
}

.demo-btn:hover {
    border-color: var(--bitcoin-orange);
    background: var(--bitcoin-orange);
    color: white;
}

/* ===== Results Panel ===== */
.results-panel {
    animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.section-title {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
}

.section-subtitle {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
}

/* ===== Story Section ===== */
.story-section {
    margin-bottom: 3rem;
}

.story-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
}

.story-card {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    border-left: 4px solid var(--bitcoin-orange);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
}

.story-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
}

.story-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
}

.story-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
}

.story-main {
    font-size: 1.15rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    font-weight: 500;
}

.story-detail {
    color: var(--text-secondary);
    font-size: 0.95rem;
}

/* Story Card Variants */
.story-who {
    border-left-color: var(--info);
}

.story-cost {
    border-left-color: var(--warning);
}

.story-risk {
    border-left-color: var(--success);
}

.story-risk.has-warnings {
    border-left-color: var(--error);
}

/* Fee Meter */
.fee-meter {
    margin-top: 1rem;
    height: 8px;
    background: var(--bg-elevated);
    border-radius: 4px;
    overflow: hidden;
    position: relative;
}

.fee-meter-fill {
    height: 100%;
    background: var(--warning);
    transition: width var(--transition-slow);
    border-radius: 4px;
}

.fee-meter-label {
    position: absolute;
    right: 0;
    top: 12px;
    font-size: 0.8rem;
    color: var(--text-muted);
}

/* Risk List */
.risk-list {
    list-style: none;
    margin-top: 0.5rem;
}

.risk-list li {
    padding: 0.4rem 0;
    padding-left: 1.5rem;
    position: relative;
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.risk-list li::before {
    content: '⚠️';
    position: absolute;
    left: 0;
}

/* ===== Flow Section ===== */
.flow-section {
    margin-bottom: 3rem;
}

.flow-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    padding: 2rem;
    margin-bottom: 2rem;
}

/* Flow Columns */
.flow-column {
    min-width: 0;
}

.column-header {
    text-align: center;
    margin-bottom: 1.5rem;
}

.column-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.5rem;
}

.column-header h3 {
    font-size: 1.1rem;
    color: var(--text-primary);
}

.column-subtitle {
    font-size: 0.85rem;
    color: var(--text-muted);
}

.flow-items {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

/* Flow Item (Input/Output Box) */
.flow-item {
    background: var(--bg-elevated);
    border-radius: var(--radius-md);
    padding: 1rem;
    border-left: 3px solid var(--bitcoin-orange);
    transition: all var(--transition-fast);
}

.flow-item:hover {
    background: var(--bg-input);
}

.flow-item.input-item {
    border-left-color: var(--info);
}

.flow-item.output-item {
    border-left-color: var(--success);
}

.flow-item.op-return {
    border-left-color: var(--text-muted);
    opacity: 0.85;
}

.flow-item-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
}

.script-badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background: var(--bg-card);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--text-secondary);
}

.input-item .script-badge {
    color: var(--info);
}

.output-item .script-badge {
    color: var(--success);
}

.flow-item-value {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--bitcoin-orange);
}

.flow-item-address {
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 0.8rem;
    color: var(--text-muted);
    word-break: break-all;
}

.op-return-data {
    margin-top: 0.5rem;
    padding: 0.5rem;
    background: var(--bg-card);
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    color: var(--text-secondary);
}

.op-return-protocol {
    color: var(--warning);
    font-weight: 500;
}

/* Column Total */
.column-total {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--bg-elevated);
    display: flex;
    justify-content: space-between;
    font-weight: 500;
}

.total-value {
    color: var(--bitcoin-orange);
    font-weight: 700;
}

/* Flow Center */
.flow-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 120px;
    padding: 1rem;
}

.flow-lines {
    flex: 1;
    width: 100%;
    position: relative;
}

.flow-lines::before {
    content: '→';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 3rem;
    color: var(--bitcoin-orange);
    opacity: 0.3;
}

/* Fee Slice (The Missing Piece) */
.fee-slice {
    background: linear-gradient(135deg, var(--error) 0%, #c74040 100%);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    text-align: center;
    box-shadow: var(--shadow-md);
    animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {

    0%,
    100% {
        box-shadow: var(--shadow-md);
    }

    50% {
        box-shadow: 0 0 20px rgba(248, 81, 73, 0.5);
    }
}

.fee-slice-inner {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}

.fee-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.9;
}

.fee-value {
    font-size: 1.1rem;
    font-weight: 700;
}

.fee-explanation {
    font-size: 0.75rem;
    opacity: 0.8;
    cursor: help;
    text-decoration: underline dotted;
}

/* Balance Bar */
.balance-bar-container {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
}

.balance-bar-container h4 {
    margin-bottom: 1rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
}

.balance-bar {
    height: 40px;
    background: var(--bg-elevated);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: flex;
}

.balance-outputs {
    background: linear-gradient(90deg, var(--success) 0%, #2ea043 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
    font-size: 0.85rem;
    transition: width var(--transition-slow);
    min-width: fit-content;
    padding: 0 0.5rem;
}

.balance-fee {
    background: linear-gradient(90deg, var(--error) 0%, #c74040 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
    font-size: 0.85rem;
    transition: width var(--transition-slow);
    min-width: fit-content;
    padding: 0 0.5rem;
}

.balance-legend {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 1rem;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
}

.legend-color {
    width: 12px;
    height: 12px;
    border-radius: 3px;
}

.legend-color.outputs {
    background: var(--success);
}

.legend-color.fee {
    background: var(--error);
}

/* ===== Technical Section ===== */
.tech-section {
    margin-bottom: 2rem;
}

.tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.tech-card {
    background: var(--bg-card);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
}

.tech-card-wide {
    grid-column: span 2;
}

.tech-card h4 {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.tech-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.tech-value {
    font-size: 1rem;
    color: var(--text-primary);
    font-weight: 500;
    word-break: break-all;
    flex: 1;
}

.tech-hint {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
}

.monospace {
    font-family: 'Monaco', 'Menlo', 'Fira Code', monospace;
    font-size: 0.85rem;
}

/* Info Icon */
.info-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    font-size: 0.7rem;
    background: var(--bg-elevated);
    border-radius: 50%;
    cursor: help;
}

/* Copy Button */
.copy-btn {
    padding: 0.4rem 0.6rem;
    background: var(--bg-elevated);
    border: none;
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 0.9rem;
    transition: all var(--transition-fast);
    flex-shrink: 0;
}

.copy-btn:hover {
    background: var(--bitcoin-orange);
    color: white;
}

.copy-btn.copied {
    background: var(--success);
}

/* SegWit Savings */
.segwit-savings {
    background: var(--success-bg);
    border: 1px solid var(--success);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
}

.segwit-savings h4 {
    color: var(--success);
    margin-bottom: 1rem;
    font-size: 1rem;
}

.savings-visual {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.savings-row {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.savings-label {
    width: 140px;
    font-size: 0.85rem;
    color: var(--text-secondary);
    flex-shrink: 0;
}

.savings-bar {
    flex: 1;
    height: 24px;
    background: var(--bg-card);
    border-radius: var(--radius-sm);
    overflow: hidden;
}

.savings-fill {
    height: 100%;
    transition: width var(--transition-slow);
}

.savings-fill.actual {
    background: var(--success);
}

.savings-fill.legacy {
    background: var(--text-muted);
}

.savings-value {
    width: 80px;
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-align: right;
}

.savings-text {
    margin-top: 1rem;
    color: var(--success);
    font-weight: 600;
    font-size: 1.1rem;
    text-align: center;
}

/* Raw JSON */
.raw-json-section {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    overflow: hidden;
}

.raw-json-section summary {
    padding: 1rem 1.5rem;
    cursor: pointer;
    color: var(--text-secondary);
    font-weight: 500;
    transition: background var(--transition-fast);
}

.raw-json-section summary:hover {
    background: var(--bg-elevated);
}

.raw-json-section pre {
    padding: 1.5rem;
    background: var(--bg-input);
    overflow-x: auto;
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--text-secondary);
    max-height: 400px;
}

/* ===== Actions ===== */
.actions {
    text-align: center;
    padding: 2rem 0;
}

.btn-back {
    padding: 0.75rem 2rem;
    background: transparent;
    border: 2px solid var(--text-muted);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: 1rem;
    cursor: pointer;
    transition: all var(--transition-fast);
}

.btn-back:hover {
    border-color: var(--bitcoin-orange);
    color: var(--bitcoin-orange);
}

/* ===== Error Panel ===== */
.error-panel {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
}

.error-card {
    background: var(--error-bg);
    border: 1px solid var(--error);
    border-radius: var(--radius-xl);
    padding: 3rem;
    text-align: center;
    max-width: 500px;
}

.error-icon {
    font-size: 4rem;
    display: block;
    margin-bottom: 1rem;
}

.error-card h2 {
    color: var(--error);
    margin-bottom: 1rem;
}

.error-code {
    font-family: monospace;
    color: var(--error);
    font-weight: 600;
    margin-bottom: 0.5rem;
}

.error-message {
    color: var(--text-secondary);
    margin-bottom: 2rem;
}

/* ===== Tooltip ===== */
.term {
    cursor: help;
    border-bottom: 1px dotted var(--text-muted);
}

.tooltip {
    position: fixed;
    background: var(--bg-elevated);
    border: 1px solid var(--text-muted);
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    color: var(--text-primary);
    max-width: 300px;
    z-index: 1000;
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--transition-fast);
    box-shadow: var(--shadow-lg);
    line-height: 1.5;
}

.tooltip.visible {
    opacity: 1;
}

/* ===== Footer ===== */
.footer {
    text-align: center;
    padding: 2rem 0;
    color: var(--text-muted);
    font-size: 0.9rem;
}

/* ===== Responsive ===== */
@media (max-width: 900px) {
    .app {
        padding: 1rem;
    }

    .flow-container {
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    .flow-center {
        order: -1;
        flex-direction: row;
        gap: 1rem;
    }

    .flow-lines::before {
        content: '↓';
    }

    .tech-card-wide {
        grid-column: span 1;
    }

    .savings-row {
        flex-direction: column;
        align-items: stretch;
        gap: 0.5rem;
    }

    .savings-label {
        width: auto;
    }

    .savings-value {
        width: auto;
        text-align: left;
    }
}

@media (max-width: 600px) {
    .logo h1 {
        font-size: 1.8rem;
    }

    .story-cards {
        grid-template-columns: 1fr;
    }

    .demo-options {
        flex-direction: column;
    }

    .demo-btn {
        width: 100%;
    }

    .balance-legend {
        flex-direction: column;
        gap: 0.5rem;
        align-items: center;
    }
}

/* ===== Animation Classes ===== */
.fade-in {
    animation: fadeIn 0.5s ease;
}

.slide-up {
    animation: slideUp 0.5s ease;
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Flow animation */
.flow-item {
    animation: slideIn 0.3s ease;
    animation-fill-mode: both;
}

.inputs-column .flow-item:nth-child(1) {
    animation-delay: 0.1s;
}

.inputs-column .flow-item:nth-child(2) {
    animation-delay: 0.2s;
}

.inputs-column .flow-item:nth-child(3) {
    animation-delay: 0.3s;
}

.inputs-column .flow-item:nth-child(4) {
    animation-delay: 0.4s;
}

.outputs-column .flow-item:nth-child(1) {
    animation-delay: 0.15s;
}

.outputs-column .flow-item:nth-child(2) {
    animation-delay: 0.25s;
}

.outputs-column .flow-item:nth-child(3) {
    animation-delay: 0.35s;
}

.outputs-column .flow-item:nth-child(4) {
    animation-delay: 0.45s;
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateX(-20px);
    }

    to {
        opacity: 1;
        transform: translateX(0);
    }
}

.outputs-column .flow-item {
    animation-name: slideInRight;
}

@keyframes slideInRight {
    from {
        opacity: 0;
        transform: translateX(20px);
    }

    to {
        opacity: 1;
        transform: translateX(0);
    }
}